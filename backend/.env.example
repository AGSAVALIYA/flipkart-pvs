# Flipkart PVS — Backend Environment Variables Example
# Copy this file to '.env' and modify for your local configuration.

# Database Connections (Alembic & SQLAlchemy Async)
DATABASE_URL=postgresql+asyncpg://flipkart_admin:password123@db:5432/product_verification
DATABASE_URL_SYNC=postgresql://flipkart_admin:password123@db:5432/product_verification

# Redis Connection (Cache-aside & rate limiting)
REDIS_URL=redis://redis:6379/0

# Local File Storage Paths
UPLOAD_DIR=/workspace/uploads
IMAGE_DIR=/workspace/images

# Security & JWT Tokens
JWT_SECRET_KEY=dev-secret-key-change-in-production-immediately
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Gemini Vision AI Integration
AI_PROVIDER=gemini
AI_PROVIDER_API_KEY=YOUR_GEMINI_API_KEY_HERE
AI_TIMEOUT_SECONDS=30

# Feature Flags
ENABLE_RBAC=true
ENABLE_VISION_AI=true

# Logfire Observability
LOGFIRE_SERVICE_NAME=flipkart-pvs
LOGFIRE_ENVIRONMENT=development

# Allowed CORS Origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
